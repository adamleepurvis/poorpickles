# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ── Yahoo Fantasy API ──────────────────────────────────────────────────────────
# Get these from https://developer.yahoo.com/apps/
# App settings: Redirect URI = oob, Permissions = Fantasy Sports (Read)

YAHOO_CONSUMER_KEY=your_consumer_key_here
YAHOO_CONSUMER_SECRET=your_consumer_secret_here

# Your league key — format: GAME_ID.l.LEAGUE_ID
# 2026 MLB game ID = 458
# Find your league ID in the Yahoo Fantasy Baseball URL
# Example: https://baseball.fantasysports.yahoo.com/b1/123456 → league ID is 123456
YAHOO_LEAGUE_KEY=458.l.your_league_id_here
